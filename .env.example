# Copia este archivo a .env en la raíz del proyecto y rellena los valores.
# Nunca subas .env a un repositorio (está en .gitignore).

# --- Syscom API (developers.syscom.mx) — elige UNA forma de autenticación ---

# Opción A: OAuth2 client_credentials (recomendado)
SISCOM_CLIENT_ID=
SISCOM_CLIENT_SECRET=

# URL del token (por defecto la de Syscom)
# SISCOM_OAUTH_TOKEN_URL=https://developers.syscom.mx/oauth/token

# Opción B: Bearer fijo (por ejemplo para pruebas; expira según expires_in)
# SISCOM_API_BEARER_TOKEN=

# Opción C: clave en cabecera personalizada
# SISCOM_API_KEY=
# SISCOM_API_KEY_HEADER=X-API-Key

# Base de la API (por defecto developers.syscom.mx)
# SISCOM_API_BASE_URL=https://developers.syscom.mx

# Catálogo /api/v1/productos
# SISCOM_CATALOGO_DEFAULT_BUSQUEDA=camaras
# SISCOM_CATALOGO_STOCK=1

# Tipo de cambio USD→MXN: qué campo usar de /api/v1/tipocambio
# (normal | preferencial | un_dia | una_semana | dos_semanas | tres_semanas | un_mes)
# SISCOM_TIPO_CAMBIO_KEY=normal
# SISCOM_TIPO_CAMBIO_PATH=/api/v1/tipocambio
